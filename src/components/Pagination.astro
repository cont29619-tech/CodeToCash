---
interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

// Page 1 lives at /blog; pages 2..N live at /blog/page/N.
const href = (page: number) => (page <= 1 ? '/blog' : `/blog/page/${page}`);

// Windowed page list: always show first, last, current ±1, with ellipsis gaps.
const pages: (number | 'gap')[] = [];
for (let p = 1; p <= totalPages; p++) {
  if (p === 1 || p === totalPages || Math.abs(p - currentPage) <= 1) {
    pages.push(p);
  } else if (pages[pages.length - 1] !== 'gap') {
    pages.push('gap');
  }
}

const baseLink = 'px-3.5 py-2 rounded-lg border text-sm font-medium transition-all';
const inactive =
  'bg-white/5 border-white/10 text-gray-300 hover:bg-white/10 hover:text-white hover:border-white/20';
const active = 'bg-coral/10 border-coral/20 text-coral';
---

{
  totalPages > 1 && (
    <nav
      aria-label="Blog pagination"
      class="mt-12 flex flex-wrap items-center justify-center gap-2"
    >
      {currentPage > 1 && (
        <a
          href={href(currentPage - 1)}
          class={`${baseLink} ${inactive}`}
          aria-label="Previous page"
        >
          ← Prev
        </a>
      )}

      {pages.map((p) =>
        p === 'gap' ? (
          <span class="px-2 text-gray-600 select-none">…</span>
        ) : (
          <a
            href={href(p)}
            class={`${baseLink} ${p === currentPage ? active : inactive}`}
            aria-label={`Page ${p}`}
            aria-current={p === currentPage ? 'page' : undefined}
          >
            {p}
          </a>
        )
      )}

      {currentPage < totalPages && (
        <a href={href(currentPage + 1)} class={`${baseLink} ${inactive}`} aria-label="Next page">
          Next →
        </a>
      )}
    </nav>
  )
}
