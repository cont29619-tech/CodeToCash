---
import { getCollection } from 'astro:content';
import { categoryColors, categoryLabels } from '../utils/categoryColors';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  showFeatured?: boolean;
  // Optional explicit hero post. When omitted, falls back to the flagged featured post
  // (or the first post). Passing this lets a caller feature a post that isn't in `posts`.
  featuredPost?: CollectionEntry<'blog'>;
}

const { posts, showFeatured = true, featuredPost: explicitFeatured } = Astro.props;

const featuredPost = showFeatured
  ? explicitFeatured || posts.find((p) => p.data.featured) || posts[0]
  : null;
const regularPosts = featuredPost ? posts.filter((p) => p.id !== featuredPost.id) : posts;
---

{
  featuredPost && (
    <a
      href={`/blog/${featuredPost.id}`}
      class={`group relative block mb-14 p-6 md:p-8 rounded-2xl border-l-4 ${categoryColors[featuredPost.data.category].borderLeft} border border-white/[0.08] bg-gradient-to-br from-white/[0.03] to-white/[0.01] ${categoryColors[featuredPost.data.category].hoverBorder} ${categoryColors[featuredPost.data.category].hoverBg} hover:shadow-xl ${categoryColors[featuredPost.data.category].hoverShadow} transition-all duration-300 overflow-hidden`}
    >
      <div
        class={`absolute top-0 right-0 w-[400px] h-[300px] rounded-full blur-[100px] pointer-events-none opacity-30 ${categoryColors[featuredPost.data.category].bg}`}
        aria-hidden="true"
      />
      <div class="relative z-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="px-2.5 py-1 rounded-md text-xs font-bold uppercase tracking-wide bg-coral/20 text-coral border border-coral/30">
            Featured
          </span>
          <span
            class={`px-2 py-0.5 rounded-md text-xs font-medium ${categoryColors[featuredPost.data.category].bg} ${categoryColors[featuredPost.data.category].text} border ${categoryColors[featuredPost.data.category].border}`}
          >
            {categoryLabels[featuredPost.data.category]}
          </span>
          <span class="text-xs text-gray-500">{featuredPost.data.readingTime}</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-white group-hover:text-coral transition-colors mb-3 leading-tight">
          {featuredPost.data.title}
        </h2>
        <p class="text-gray-400 leading-relaxed mb-4 max-w-2xl">{featuredPost.data.description}</p>
        <div class="flex items-center text-sm text-coral/70 group-hover:text-coral transition-colors font-medium">
          Read article
          <svg
            class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"
            />
          </svg>
        </div>
      </div>
    </a>
  )
}

<div class="grid gap-6 md:grid-cols-2">
  {
    regularPosts.map((post) => {
      const pc = categoryColors[post.data.category] || categoryColors.fundamentals;
      const date = post.data.pubDate.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
      return (
        <a
          href={`/blog/${post.id}`}
          class={`group relative flex flex-col p-6 bg-navy-light border border-white/[0.06] border-l-2 ${pc.borderLeft} rounded-2xl ${pc.hoverBorder} ${pc.hoverBg} hover:shadow-lg ${pc.hoverShadow} transition-all duration-300 hover:-translate-y-0.5 overflow-hidden`}
        >
          <div class="flex items-center gap-2 mb-3">
            <span
              class={`inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium ${pc.bg} ${pc.text} border ${pc.border}`}
            >
              {categoryLabels[post.data.category]}
            </span>
            <span class="inline-flex items-center gap-1 text-xs text-gray-500">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
              {post.data.readingTime}
            </span>
          </div>
          <h2 class="text-lg font-semibold text-white group-hover:text-coral transition-colors mb-2 leading-snug">
            {post.data.title}
          </h2>
          <p class="text-sm text-gray-400 leading-relaxed flex-1 mb-4">{post.data.description}</p>
          <div class="flex items-center justify-between pt-4 border-t border-white/5">
            <span class="text-xs text-gray-500">{date}</span>
            <span
              class={`flex items-center text-sm ${pc.text} opacity-70 group-hover:opacity-100 transition-all`}
            >
              Read
              <svg
                class="w-3.5 h-3.5 ml-1 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </span>
          </div>
        </a>
      );
    })
  }
</div>
