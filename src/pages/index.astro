<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.section-animate').forEach((el) => {
    observer.observe(el);
  });

  // Inject code decoration after paint so h1 is the LCP element
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const el = document.getElementById('code-decoration');
      if (el) {
        el.innerHTML = `<pre class="font-mono text-xs sm:text-sm text-white leading-relaxed absolute top-8 -left-8 rotate-[-3deg]">const pipeline = async (visitor) =&gt; {
  const lead = await captureEmail(visitor);
  const qualified = await nurture(lead);
  const customer = await presentOffer(qualified);
  return customer.revenue;
};

function buildLandingPage(product) {
  return {
    headline: solveMainProblem(product),
    subhead: agitate(product.audience),
    cta: irresistibleOffer(product),
    proof: gatherTestimonials(),
  };
}

// deploy &amp;&amp; measure &amp;&amp; iterate
const results = await abTest(pageA, pageB);
const winner = results.conversionRate &gt; 0.03
  ? results.variant
  : optimize(results);</pre>`;
        el.style.opacity = '0.03';
      }
    });
  });
</script>
