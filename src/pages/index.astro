---
import Layout from '../layouts/Layout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const publishedPosts = await getCollection('blog', ({ data }) => !data.draft);
const articleCount = publishedPosts.length;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CodeToCash.dev',
  url: 'https://codetocash.dev',
  description:
    'Direct response marketing education for vibe coders and indie developers who ship products but struggle with sales.',
  publisher: {
    '@type': 'Organization',
    name: 'CodeToCash.dev',
  },
});
---

<Layout
  description="You can build it. But can you sell it? Free DRM frameworks for vibe coders and indie devs who ship great products and earn $0 from them. Change that today."
  schema={schema}
>
  <!-- ============ HERO SECTION ============ -->
  <section
    class="relative overflow-hidden min-h-[90vh] flex items-center justify-center px-4 py-24"
  >
    <!-- Background glows -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[700px] bg-coral/6 rounded-full blur-[80px] md:blur-[140px] animate-pulse-slow"
      >
      </div>
      <div
        class="absolute top-1/3 left-1/3 w-[500px] h-[500px] bg-deep-blue/15 rounded-full hidden md:block blur-[120px] animate-pulse-slow animation-delay-2000"
      >
      </div>
      <div
        class="absolute bottom-1/4 right-1/4 w-[300px] h-[300px] bg-coral/4 rounded-full hidden lg:block blur-[100px] animate-pulse-slow animation-delay-400"
      >
      </div>
    </div>
    <!-- Faded code decoration (loaded after paint to avoid LCP penalty) -->
    <div
      id="code-decoration"
      class="absolute inset-0 pointer-events-none overflow-hidden opacity-0 select-none"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p
        class="inline-block text-sm font-mono text-coral uppercase tracking-widest mb-6 animate-fade-in"
      >
        // ship products, make money
      </p>
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] tracking-tight animate-fade-in-up"
      >
        You Can Build Anything.<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-coral"
          >Now Learn to Sell It.</span
        >
      </h1>
      <p
        class="mt-6 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed animate-fade-in-up animation-delay-200"
      >
        You shipped it. Now sell it. A free marketing guide for vibe coders and indie developers —
        built in public, written in plain English.
      </p>
      <div
        class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up animation-delay-400"
      >
        <a
          href="/drm-101"
          class="px-8 py-4 bg-coral text-white text-lg font-semibold rounded-lg hover:bg-coral/90 hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-coral/30"
        >
          Start the Free DRM 101 Guide
        </a>
        <a
          href="/newsletter"
          class="px-8 py-4 border-2 border-coral/50 text-coral text-lg font-medium rounded-lg hover:bg-coral/10 hover:border-coral hover:-translate-y-1 transition-all duration-300"
        >
          Get the Free Cheatsheet
        </a>
      </div>
    </div>
  </section>

  <!-- ============ PROBLEM SECTION ============ -->
  <section class="relative px-4 py-24 sm:py-32 border-t border-white/[0.02] overflow-hidden">
    <!-- Subtle red/warning tint to signal "this is the problem" -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-red-950/20 via-navy-light/60 to-navy pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-red-500/20 to-transparent"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16 section-animate">
        <p class="text-sm font-mono text-red-400/80 uppercase tracking-widest mb-4">
          // the problem
        </p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
          The Vibe Coder's Marketing Problem
        </h2>
        <p class="mt-6 text-lg text-gray-400 leading-relaxed">
          You can vibe code an entire SaaS in a weekend with Cursor, Bolt, or Lovable. But then
          what? You post it on Twitter, get 12 likes, and wonder why nobody is buying.
        </p>
        <p class="mt-4 text-lg text-gray-400 leading-relaxed">
          The problem isn't your product — it's that <span class="text-white font-medium"
            >nobody taught you how to sell</span
          >. Traditional marketing advice feels like it's written for MBAs, not makers.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card: red accent — launch/traction problem -->
        <div
          class="group relative p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-red-500/30 hover:bg-red-950/10 hover:shadow-lg hover:shadow-red-900/20 hover:-translate-y-1 transition-all duration-300 section-animate overflow-hidden"
        >
          <div
            class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-red-500/50 to-transparent"
          >
          </div>
          <div
            class="text-4xl mb-5 group-hover:scale-110 transition-transform duration-300"
            aria-hidden="true"
          >
            🚀
          </div>
          <h3 class="text-xl font-bold text-white mb-3">You Build, But Nobody Buys</h3>
          <p class="text-gray-400 leading-relaxed">
            Great product, zero revenue. You shipped something amazing but your launch got buried in
            the noise.
          </p>
        </div>
        <!-- Card: yellow accent — sleazy marketing problem -->
        <div
          class="group relative p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-yellow-500/30 hover:bg-yellow-950/10 hover:shadow-lg hover:shadow-yellow-900/20 hover:-translate-y-1 transition-all duration-300 section-animate overflow-hidden"
        >
          <div
            class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-yellow-500/50 to-transparent"
          >
          </div>
          <div
            class="text-4xl mb-5 group-hover:scale-110 transition-transform duration-300"
            aria-hidden="true"
          >
            😬
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Marketing Feels Sleazy</h3>
          <p class="text-gray-400 leading-relaxed">
            You'd rather write code than write copy. Every marketing tactic you've seen feels
            manipulative or cringe.
          </p>
        </div>
        <!-- Card: gray/slate accent — no system problem -->
        <div
          class="group relative p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-slate-400/30 hover:bg-slate-900/20 hover:shadow-lg hover:shadow-slate-900/20 hover:-translate-y-1 transition-all duration-300 section-animate overflow-hidden"
        >
          <div
            class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-slate-400/40 to-transparent"
          >
          </div>
          <div
            class="text-4xl mb-5 group-hover:scale-110 transition-transform duration-300"
            aria-hidden="true"
          >
            🎲
          </div>
          <h3 class="text-xl font-bold text-white mb-3">No System, Just Hoping</h3>
          <p class="text-gray-400 leading-relaxed">
            Posting randomly and praying for sales. No funnel, no strategy, no repeatable process to
            grow revenue.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SOLUTION SECTION ============ -->
  <section class="relative px-4 py-24 sm:py-32 border-t border-white/[0.02] overflow-hidden">
    <!-- Deep blue tint + dot grid pattern -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-deep-blue/20 via-navy to-navy pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 28px 28px;"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-deep-blue/60 to-transparent"
      aria-hidden="true"
    >
    </div>
    <!-- Glow behind terminal -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] bg-deep-blue/20 rounded-full blur-[100px] pointer-events-none"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16 section-animate">
        <p class="text-sm font-mono text-blue-400/80 uppercase tracking-widest mb-4">
          // the solution
        </p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
          Direct Response Marketing:<br />Your Sales Algorithm
        </h2>
        <p class="mt-6 text-lg text-gray-400 leading-relaxed">
          Think of DRM as a function. <span class="font-mono text-blue-400/80">Input: visitor</span
          >. <span class="font-mono text-coral/80">Output: customer</span>. Every element is
          testable. Every result is measurable. It's marketing for people who think in systems.
        </p>
      </div>

      <!-- DRM Pipeline -->
      <div class="max-w-4xl mx-auto section-animate">
        <div
          class="rounded-2xl bg-white/[0.03] border border-white/[0.08] overflow-hidden shadow-2xl shadow-deep-blue/20"
        >
          <!-- Terminal header -->
          <div
            class="flex items-center gap-2 px-5 py-3 bg-white/[0.04] border-b border-white/[0.08]"
          >
            <span class="w-3 h-3 rounded-full bg-coral/70"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
            <span class="ml-3 text-xs font-mono text-gray-500">drm-pipeline.ts</span>
          </div>
          <!-- Terminal body -->
          <div class="p-6 sm:p-8 font-mono text-sm sm:text-base leading-loose">
            <p class="text-gray-500">// Your direct response marketing pipeline</p>
            <p class="text-gray-500">// Every step is measurable, every result is optimizable</p>
            <p class="mt-4">
              <span class="text-purple-400">const</span>
              <span class="text-white"> pipeline</span>
              <span class="text-coral"> =</span>
              <span class="text-white"> [</span>
            </p>
            <div class="ml-4 sm:ml-8 space-y-3 my-3">
              <p>
                <span class="text-green-400">"Traffic"</span><span class="text-gray-500">,</span>
                <span class="text-gray-600 ml-6">// SEO, ads, content, social</span>
              </p>
              <p>
                <span class="text-green-400">"Landing Page"</span><span class="text-gray-500"
                  >,</span
                >
                <span class="text-gray-600 ml-3">// Convert visitors to leads</span>
              </p>
              <p>
                <span class="text-green-400">"Email Sequence"</span><span class="text-gray-500"
                  >,</span
                >
                <span class="text-gray-600 ml-1">// Nurture &amp; build trust</span>
              </p>
              <p>
                <span class="text-green-400">"Offer"</span><span class="text-gray-500">,</span>
                <span class="text-gray-600 ml-10">// Present irresistible deal</span>
              </p>
              <p>
                <span class="text-green-400">"Revenue"</span><span class="text-gray-500">,</span>
                <span class="text-gray-600 ml-7">// $$$</span>
              </p>
            </div>
            <p><span class="text-white">];</span></p>
            <p class="mt-4">
              <span class="text-purple-400">const</span>
              <span class="text-white"> result</span>
              <span class="text-coral"> =</span>
              <span class="text-yellow-300"> runPipeline</span><span class="text-white"
                >(pipeline);</span
              >
            </p>
            <p>
              <span class="text-gray-500">// =&gt; </span>
              <span class="text-coral font-bold"
                >&#123; revenue: "recurring", confidence: "data-driven" &#125;</span
              >
            </p>
          </div>
        </div>

        <!-- Pipeline visual (mobile-friendly) -->
        <div
          class="mt-10 flex flex-wrap items-center justify-center gap-3 text-sm font-mono section-animate cursor-default"
        >
          <span
            class="px-4 py-2 rounded-lg bg-deep-blue/40 border border-deep-blue/60 text-gray-200 hover:scale-105 hover:border-coral/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-coral/20 hover:text-white transition-all duration-300"
            >Traffic</span
          >
          <span class="text-coral text-lg animate-pulse">→</span>
          <span
            class="px-4 py-2 rounded-lg bg-deep-blue/40 border border-deep-blue/60 text-gray-200 hover:scale-105 hover:border-coral/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-coral/20 hover:text-white transition-all duration-300"
            >Landing Page</span
          >
          <span class="text-coral text-lg animate-pulse">→</span>
          <span
            class="px-4 py-2 rounded-lg bg-deep-blue/40 border border-deep-blue/60 text-gray-200 hover:scale-105 hover:border-coral/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-coral/20 hover:text-white transition-all duration-300"
            >Email Sequence</span
          >
          <span class="text-coral text-lg animate-pulse">→</span>
          <span
            class="px-4 py-2 rounded-lg bg-deep-blue/40 border border-deep-blue/60 text-gray-200 hover:scale-105 hover:border-coral/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-coral/20 hover:text-white transition-all duration-300"
            >Offer</span
          >
          <span class="text-coral text-lg animate-pulse">→</span>
          <span
            class="px-4 py-2 rounded-lg bg-coral/20 border border-coral/40 text-coral font-semibold hover:scale-105 hover:bg-coral/30 hover:shadow-lg hover:shadow-coral/40 hover:-translate-y-1 transition-all duration-300"
            >Revenue</span
          >
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT YOU'LL LEARN SECTION ============ -->
  <section class="relative px-4 py-24 sm:py-32 border-t border-white/[0.02] overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-b from-navy-light/70 to-navy pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16 section-animate">
        <p class="text-sm font-mono text-coral uppercase tracking-widest mb-4">// the curriculum</p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
          What You'll Learn at CodeToCash
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Card 1: Landing Pages — blue -->
        <div
          class="group p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-blue-500/30 hover:bg-blue-950/10 hover:-translate-y-1 hover:shadow-lg hover:shadow-blue-900/20 transition-all duration-300 section-animate"
        >
          <div
            class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-5 group-hover:bg-blue-500/15 transition-colors duration-300"
          >
            <svg
              class="w-6 h-6 text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18"></path><path
                d="M9 21V9"></path></svg
            >
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Landing Pages That Convert</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Turn visitors into customers with proven page structures and conversion-optimized
            layouts.
          </p>
        </div>
        <!-- Card 2: Copywriting — purple -->
        <div
          class="group p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-purple-500/30 hover:bg-purple-950/10 hover:-translate-y-1 hover:shadow-lg hover:shadow-purple-900/20 transition-all duration-300 section-animate"
        >
          <div
            class="w-12 h-12 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center mb-5 group-hover:bg-purple-500/15 transition-colors duration-300"
          >
            <svg
              class="w-6 h-6 text-purple-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M12 20h9"></path><path
                d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"
              ></path></svg
            >
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Copywriting for Developers</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Frameworks that make writing sales copy feel like filling in a template. No creative
            writing degree needed.
          </p>
        </div>
        <!-- Card 3: Email — green -->
        <div
          class="group p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-green-500/30 hover:bg-green-950/10 hover:-translate-y-1 hover:shadow-lg hover:shadow-green-900/20 transition-all duration-300 section-animate"
        >
          <div
            class="w-12 h-12 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center mb-5 group-hover:bg-green-500/15 transition-colors duration-300"
          >
            <svg
              class="w-6 h-6 text-green-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
            >
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Email Sequences That Sell</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Automated email flows that nurture leads and drive revenue while you sleep. Set up once,
            iterate as you grow.
          </p>
        </div>
        <!-- Card 4: Ads — yellow -->
        <div
          class="group p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-yellow-500/30 hover:bg-yellow-950/10 hover:-translate-y-1 hover:shadow-lg hover:shadow-yellow-900/20 transition-all duration-300 section-animate"
        >
          <div
            class="w-12 h-12 rounded-xl bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center mb-5 group-hover:bg-yellow-500/15 transition-colors duration-300"
          >
            <svg
              class="w-6 h-6 text-yellow-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg
            >
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Your First Ad Campaign</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Run paid ads without burning cash, even on a tiny budget. Learn to test, measure, and
            scale what works.
          </p>
        </div>
        <!-- Card 5: Pricing — orange -->
        <div
          class="group p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-orange-500/30 hover:bg-orange-950/10 hover:-translate-y-1 hover:shadow-lg hover:shadow-orange-900/20 transition-all duration-300 section-animate"
        >
          <div
            class="w-12 h-12 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center mb-5 group-hover:bg-orange-500/15 transition-colors duration-300"
          >
            <svg
              class="w-6 h-6 text-orange-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><line x1="12" y1="1" x2="12" y2="23"></line><path
                d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg
            >
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Pricing Strategies</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Price your SaaS, tool, or template to maximize revenue. Stop guessing and start using
            proven pricing models.
          </p>
        </div>
        <!-- Card 6: Analytics — cyan -->
        <div
          class="group p-8 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-cyan-500/30 hover:bg-cyan-950/10 hover:-translate-y-1 hover:shadow-lg hover:shadow-cyan-900/20 transition-all duration-300 section-animate"
        >
          <div
            class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center mb-5 group-hover:bg-cyan-500/15 transition-colors duration-300"
          >
            <svg
              class="w-6 h-6 text-cyan-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M3 3v16a2 2 0 0 0 2 2h16"></path><path d="m19 9-5 5-4-4-3 3"></path></svg
            >
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Analytics & Testing</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            A/B test everything and make data-driven marketing decisions. Because guessing is not a
            growth strategy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BUILDING IN PUBLIC SECTION ============ -->
  <section class="relative px-4 py-24 sm:py-32 border-t border-white/[0.02] overflow-hidden">
    <!-- Subtle teal/green tint — "growth/progress" signal -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-navy via-navy-light/40 to-green-950/10 pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-green-500/15 to-transparent"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16 section-animate">
        <p class="text-sm font-mono text-green-400/70 uppercase tracking-widest mb-4">
          // real numbers, no fluff
        </p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
          What You're Getting Access To
        </h2>
        <p class="mt-6 text-lg text-gray-400 leading-relaxed">
          Every article, playbook, and template on this site is free — and we're adding more every
          week. Here's the library so far:
        </p>
      </div>

      <!-- Dashboard-style stat cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <!-- Stat 1: Articles -->
        <div
