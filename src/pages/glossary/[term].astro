---
import Layout from '../../layouts/Layout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { glossary, glossaryBySlug } from '../../data/glossary';

export function getStaticPaths() {
  return glossary.map((t) => ({ params: { term: t.slug }, props: { term: t } }));
}

const { term } = Astro.props;
const related = term.related.map((slug) => glossaryBySlug[slug]).filter(Boolean);

const pageTitle =
  term.term.length <= 47 ? `${term.term} | CodeToCash` : `${term.term} — Definition`;
const description = term.short;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTerm',
      name: term.term,
      description: term.definition,
      url: `https://codetocash.dev/glossary/${term.slug}`,
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: 'CodeToCash Marketing Glossary',
        url: 'https://codetocash.dev/glossary',
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: `What is ${term.term}?`,
          acceptedAnswer: { '@type': 'Answer', text: term.definition },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://codetocash.dev/' },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Glossary',
          item: 'https://codetocash.dev/glossary',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: term.term,
          item: `https://codetocash.dev/glossary/${term.slug}`,
        },
      ],
    },
  ],
});
---

<Layout title={pageTitle} description={description} schema={schema}>
  <!-- Breadcrumb -->
  <nav class="max-w-3xl mx-auto px-6 pt-8 pb-0" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-gray-500 flex-wrap">
      <li><a href="/" class="hover:text-coral transition-colors">Home</a></li>
      <li><span class="text-gray-700">/</span></li>
      <li><a href="/glossary" class="hover:text-coral transition-colors">Glossary</a></li>
      <li><span class="text-gray-700">/</span></li>
      <li class="text-gray-300">{term.term}</li>
    </ol>
  </nav>

  <article class="max-w-3xl mx-auto px-6 py-12 md:py-16">
    <p class="text-sm font-mono text-coral uppercase tracking-widest mb-4">// definition</p>
    <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-6">{term.term}</h1>

    <!-- Answer-first definition -->
    <p class="text-xl text-gray-200 leading-relaxed mb-10 border-l-2 border-coral pl-5">
      {term.definition}
    </p>

    <h2 class="text-2xl font-bold mb-3">Why it matters for developers</h2>
    <p class="text-lg text-gray-400 leading-relaxed mb-10">{term.whyItMatters}</p>

    {
      term.relatedPosts && term.relatedPosts.length > 0 && (
        <section class="mb-10">
          <h2 class="text-2xl font-bold mb-4">Go deeper</h2>
          <ul class="space-y-3">
            {term.relatedPosts.map((p) => (
              <li>
                <a
                  href={`/blog/${p.slug}`}
                  class="group flex items-center gap-2 text-coral hover:text-coral/80 transition-colors"
                >
                  <span class="font-medium">{p.label}</span>
                  <span class="opacity-60 group-hover:translate-x-0.5 transition-transform">→</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      related.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-bold mb-4">Related terms</h2>
          <div class="flex flex-wrap gap-2">
            {related.map((r) => (
              <a
                href={`/glossary/${r.slug}`}
                class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-white/5 text-gray-300 border border-white/10 hover:text-white hover:border-coral/40 transition-all"
              >
                {r.term}
              </a>
            ))}
          </div>
        </section>
      )
    }

    <!-- Newsletter CTA -->
    <div
      class="p-8 rounded-2xl bg-gradient-to-br from-deep-blue/40 to-navy-light border border-white/[0.06] text-center"
    >
      <h2 class="text-xl font-bold mb-2">Marketing, explained like engineering</h2>
      <p class="text-gray-400 mb-5 text-sm max-w-md mx-auto">
        One direct response marketing tactic every week, built for developers. Free.
      </p>
      <div class="max-w-md mx-auto">
        <NewsletterForm size="md" buttonText="Subscribe Free" />
      </div>
      <p class="text-sm text-gray-500 mt-5">
        New here? Start with the <a href="/drm-101" class="text-coral hover:underline"
          >DRM 101 guide</a
        > or browse the full <a href="/glossary" class="text-coral hover:underline">glossary</a>.
      </p>
    </div>
  </article>
</Layout>
