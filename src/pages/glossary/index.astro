---
import Layout from '../../layouts/Layout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { glossary } from '../../data/glossary';

const title = 'Marketing Glossary for Developers | CodeToCash';
const description =
  'Plain-English definitions of the marketing terms developers need — CAC, LTV, churn, conversion rate, SEO, GEO, and more. Each term explained for indie hackers and vibe coders.';

// Sort alphabetically by term and group by first letter.
const sorted = [...glossary].sort((a, b) => a.term.localeCompare(b.term));
const groups = sorted.reduce<Record<string, typeof glossary>>((acc, t) => {
  const letter = t.term[0].toUpperCase();
  (acc[letter] ||= []).push(t);
  return acc;
}, {});
const letters = Object.keys(groups).sort();

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'CodeToCash Marketing Glossary',
  description,
  url: 'https://codetocash.dev/glossary',
  hasDefinedTerm: sorted.map((t) => ({
    '@type': 'DefinedTerm',
    name: t.term,
    description: t.short,
    url: `https://codetocash.dev/glossary/${t.slug}`,
  })),
});
---

<Layout title={title} description={description} schema={schema}>
  <!-- Breadcrumb -->
  <nav class="max-w-5xl mx-auto px-6 pt-8 pb-0" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li><a href="/" class="hover:text-coral transition-colors">Home</a></li>
      <li><span class="text-gray-700">/</span></li>
      <li class="text-gray-300">Glossary</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden py-16 md:py-20">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 right-1/4 w-80 h-80 bg-coral/5 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <p class="text-sm font-mono text-coral uppercase tracking-widest mb-4">// glossary</p>
      <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-6">
        Marketing Glossary for Developers
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Plain-English definitions of the marketing terms you'll meet building and selling a product
        — each one explained the way a developer would want it.
      </p>
    </div>
  </section>

  <!-- A–Z jump nav -->
  <section class="max-w-5xl mx-auto px-6 mb-10">
    <nav class="flex flex-wrap gap-2 justify-center" aria-label="Jump to letter">
      {
        letters.map((letter) => (
          <a
            href={`#letter-${letter}`}
            class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-sm font-medium bg-white/5 text-gray-400 border border-white/10 hover:text-white hover:border-coral/40 transition-all"
          >
            {letter}
          </a>
        ))
      }
    </nav>
  </section>

  <div class="max-w-5xl mx-auto px-6 pb-24">
    {
      letters.map((letter) => (
        <section id={`letter-${letter}`} class="mb-12 scroll-mt-24">
          <h2 class="text-2xl font-bold text-coral mb-5">{letter}</h2>
          <div class="grid gap-5 md:grid-cols-2">
            {groups[letter].map((t) => (
              <a
                href={`/glossary/${t.slug}`}
                class="group flex flex-col p-6 bg-navy-light border border-white/[0.06] rounded-2xl hover:border-coral/40 hover:bg-white/[0.04] hover:shadow-lg hover:shadow-coral/10 transition-all duration-300 hover:-translate-y-0.5"
              >
                <h3 class="text-lg font-semibold text-white group-hover:text-coral transition-colors mb-2 leading-snug">
                  {t.term}
                </h3>
                <p class="text-sm text-gray-400 leading-relaxed">{t.short}</p>
              </a>
            ))}
          </div>
        </section>
      ))
    }

    <!-- Newsletter CTA -->
    <div
      class="mt-8 p-8 md:p-10 rounded-2xl bg-gradient-to-br from-deep-blue/40 to-navy-light border border-white/[0.06] text-center"
    >
      <h2 class="text-2xl font-bold mb-3">Learn the concepts, then apply them</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">
        One direct response marketing tactic every week, built for developers. Free.
      </p>
      <div class="max-w-md mx-auto">
        <NewsletterForm size="md" buttonText="Subscribe Free" />
      </div>
    </div>
  </div>
</Layout>
