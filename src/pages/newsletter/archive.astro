---
import Layout from '../../layouts/Layout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { newsletterIssues, newsletterTags } from '../../data/newsletterIssues';

const title = 'Newsletter Archive — CodeToCash Weekly';
const description =
  'Every issue of the CodeToCash newsletter. Actionable DRM tactics, copywriting frameworks, and marketing strategies for developers who ship.';

const sortedIssues = [...newsletterIssues].sort((a, b) => b.issue - a.issue);
const totalIssues = sortedIssues.length;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description: description,
  url: 'https://codetocash.dev/newsletter/archive',
  publisher: {
    '@type': 'Organization',
    name: 'CodeToCash.dev',
    url: 'https://codetocash.dev',
  },
  hasPart: sortedIssues.map((issue) => ({
    '@type': 'CreativeWork',
    name: issue.title,
    datePublished: issue.date,
    url: issue.link ? `https://codetocash.dev/blog/${issue.link.slug}` : undefined,
  })),
});
---

<Layout title={title} description={description} schema={schema}>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 md:py-24">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 right-1/4 w-80 h-80 bg-coral/5 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <nav
        aria-label="Breadcrumb"
        class="flex items-center justify-center gap-2 text-sm text-gray-500 mb-6"
      >
        <a href="/" class="hover:text-gray-300 transition-colors">Home</a>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
          ></path></svg
        >
        <a href="/newsletter" class="hover:text-gray-300 transition-colors">Newsletter</a>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
          ></path></svg
        >
        <span class="text-gray-400">Archive</span>
      </nav>
      <p class="text-sm font-mono text-coral uppercase tracking-widest mb-4">// every issue</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-4">
        Newsletter Archive
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        {totalIssues} issues of actionable DRM tactics for developers. One email, every week, built for
        people who ship.
      </p>
    </div>
  </section>

  <!-- Tag Filter -->
  <section class="max-w-5xl mx-auto px-6 mb-12">
    <nav class="flex flex-wrap gap-2 justify-center" aria-label="Filter issues by topic">
      {
        newsletterTags.map((tag) => (
          <button
            data-filter={tag}
            class={`filter-btn px-4 py-2 rounded-xl text-sm font-medium border transition-all cursor-pointer ${tag === 'all' ? 'bg-coral/10 text-coral border-coral/20' : 'bg-white/5 text-gray-400 border-white/10 hover:text-white hover:border-white/20'}`}
          >
            {tag}
          </button>
        ))
      }
    </nav>
  </section>

  <!-- Issues List -->
  <section class="max-w-4xl mx-auto px-6 pb-24">
    <div id="issues-list" class="space-y-6">
      {
        sortedIssues.map((issue) => {
          const date = new Date(issue.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          const href = issue.link ? `/blog/${issue.link.slug}` : '#';
          return (
            <article
              data-tags={issue.tags.join(',')}
              class="issue-card group relative flex flex-col sm:flex-row gap-5 p-6 bg-navy-light border border-white/[0.06] rounded-2xl hover:border-coral/30 hover:bg-white/[0.03] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-coral/10 transition-all duration-300"
            >
              <div class="shrink-0">
                <span class="flex items-center justify-center w-14 h-14 rounded-xl bg-coral/10 text-coral font-mono font-bold text-lg border border-coral/20">
                  {issue.issue}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span class="text-xs text-gray-500">{date}</span>
                  {issue.tags.slice(0, 3).map((tag) => (
                    <span class="px-2 py-0.5 rounded-md text-[10px] font-medium bg-white/5 text-gray-400 border border-white/10 uppercase tracking-wider">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="text-lg font-semibold text-white group-hover:text-coral transition-colors leading-snug mb-2">
                  {issue.link ? (
                    <a href={href} class="focus:outline-none">
                      {issue.title}
                      <span class="inline-flex items-center ml-1 text-coral/60 group-hover:text-coral transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"
                          />
                        </svg>
                      </span>
                    </a>
                  ) : (
                    issue.title
                  )}
                </h2>
                <p class="text-sm text-gray-400 leading-relaxed">{issue.description}</p>
              </div>
            </article>
          );
        })
      }
    </div>

    <!-- Empty State (hidden by default, shown by JS when filtering) -->
    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-gray-400 mb-2">No issues match this topic yet.</p>
      <button
        id="clear-filter"
        class="text-sm text-coral hover:text-coral/80 transition-colors cursor-pointer"
      >
        Show all issues
      </button>
    </div>

    <!-- Newsletter CTA -->
    <div
      class="mt-16 p-8 md:p-10 bg-gradient-to-br from-coral/10 to-deep-blue/30 border border-coral/20 rounded-2xl text-center"
    >
      <p class="text-sm font-mono text-coral uppercase tracking-widest mb-3">
        // never miss an issue
      </p>
      <h3 class="text-2xl font-bold text-white mb-3">Get the Next Issue in Your Inbox</h3>
      <p class="text-gray-400 mb-6 max-w-md mx-auto">
        One email every Tuesday with actionable marketing tactics for developers. Plus the free DRM
        Cheatsheet — every framework and template on one page.
      </p>
      <NewsletterForm size="md" buttonText="Subscribe Free" class="max-w-md mx-auto" />
    </div>
  </section>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const issues = document.querySelectorAll('.issue-card');
  const emptyState = document.getElementById('empty-state');
  const clearFilter = document.getElementById('clear-filter');

  function filterIssues(tag: string) {
    let visibleCount = 0;

    issues.forEach((issue) => {
      const tags = (issue.getAttribute('data-tags') || '').split(',');
      const isMatch = tag === 'all' || tags.includes(tag);

      if (isMatch) {
        (issue as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (issue as HTMLElement).style.display = 'none';
      }
    });

    if (visibleCount === 0) {
      emptyState?.classList.remove('hidden');
    } else {
      emptyState?.classList.add('hidden');
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter') || 'all';

      // Update active button
      filterBtns.forEach((b) => {
        b.classList.remove('bg-coral/10', 'text-coral', 'border-coral/20');
        b.classList.add('bg-white/5', 'text-gray-400', 'border-white/10');
      });
      btn.classList.remove('bg-white/5', 'text-gray-400', 'border-white/10');
      btn.classList.add('bg-coral/10', 'text-coral', 'border-coral/20');

      filterIssues(filter);
    });
  });

  clearFilter?.addEventListener('click', () => {
    const allBtn = document.querySelector('[data-filter="all"]');
    if (allBtn) (allBtn as HTMLElement).click();
  });
</script>
