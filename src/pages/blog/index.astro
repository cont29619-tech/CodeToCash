---
import Layout from '../../layouts/Layout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import BlogPostGrid from '../../components/BlogPostGrid.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { getBlogPagination, getPageStreamSlice } from '../../utils/blogPagination';

const title = 'Blog — Marketing Tactics for Vibe Coders | CodeToCash';
const description =
  'Actionable marketing articles for developers. Learn DRM, copywriting, email marketing, and growth strategies.';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Featured post is pinned as the page-1 hero; the rest stream chronologically.
const { featuredPost, stream, totalPages } = getBlogPagination(allPosts);
const gridPosts = getPageStreamSlice(stream, 1);

// Hand-picked starting points (editor's picks, not engagement data).
const popularSlugs = [
  'what-is-direct-response-marketing-for-developers',
  'copywriting-frameworks-for-developers',
  'saas-landing-page-copywriting',
  'email-marketing-for-saas-beginners',
  'drm-funnel-explained',
  'saas-pricing-strategy',
];
const popularPosts = popularSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean) as typeof allPosts;

const categoryCounts = allPosts.reduce<Record<string, number>>((acc, p) => {
  acc[p.data.category] = (acc[p.data.category] || 0) + 1;
  return acc;
}, {});

const categories = [
  { id: 'all', label: 'All', count: allPosts.length },
  { id: 'fundamentals', label: 'Fundamentals', count: categoryCounts.fundamentals || 0 },
  { id: 'copywriting', label: 'Copywriting', count: categoryCounts.copywriting || 0 },
  { id: 'email', label: 'Email', count: categoryCounts.email || 0 },
  { id: 'ads', label: 'Ads', count: categoryCounts.ads || 0 },
  { id: 'analytics', label: 'Analytics', count: categoryCounts.analytics || 0 },
  { id: 'strategy', label: 'Strategy', count: categoryCounts.strategy || 0 },
];

// GEO / AI Search is a tag-based hub (not a fixed category), surfaced as its own chip.
const geoCount = allPosts.filter((p) => p.data.tags.includes('geo')).length;
---

<Layout title={title} description={description} ogImage="/og/blog.png">
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 md:py-24">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 right-1/4 w-80 h-80 bg-coral/5 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
        Blog — Marketing Tactics for <span class="text-coral">Vibe Coders</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Actionable articles on direct response marketing, copywriting, and growth strategies for
        developers who ship.
      </p>
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="max-w-5xl mx-auto px-6 mb-12">
    <div class="flex items-center justify-center gap-3 mb-4">
      <p class="text-center text-sm font-mono text-coral uppercase tracking-widest">
        // browse by category
      </p>
      <button
        type="button"
        id="blog-search-btn"
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-xs text-gray-400 hover:text-white hover:border-white/20 transition-all"
        aria-label="Search articles"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Search
        <kbd class="hidden sm:inline font-mono text-[10px] text-gray-500">⌘K</kbd>
      </button>
    </div>
    <nav class="flex flex-wrap gap-2 justify-center" aria-label="Blog categories">
      {
        categories.map((cat) => (
          <a
            href={cat.id === 'all' ? '/blog' : `/blog/${cat.id}`}
            class={`inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium border transition-all ${cat.id === 'all' ? 'bg-coral/10 text-coral border-coral/20' : 'bg-white/5 text-gray-400 border-white/10 hover:text-white hover:border-white/20'}`}
            aria-current={cat.id === 'all' ? 'page' : undefined}
          >
            {cat.label}
            <span class="text-xs opacity-60">{cat.count}</span>
          </a>
        ))
      }
      {
        geoCount > 0 && (
          <a
            href="/blog/tag/geo"
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium border transition-all bg-coral/10 text-coral border-coral/30 hover:bg-coral/20 hover:border-coral/50"
          >
            GEO / AI Search
            <span class="text-xs opacity-60">{geoCount}</span>
          </a>
        )
      }
    </nav>
  </section>

  <!-- Start Here -->
  <section class="max-w-5xl mx-auto px-6 mb-14">
    <div
      class="p-6 md:p-8 rounded-2xl bg-gradient-to-br from-deep-blue/40 to-navy-light border border-white/[0.08]"
    >
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="text-xs font-mono text-coral uppercase tracking-widest mb-2">
            // new to marketing?
          </p>
          <h2 class="text-xl font-bold text-white mb-1">Start here</h2>
          <p class="text-sm text-gray-400">
            Hand-picked posts to take you from zero to selling what you build.
          </p>
        </div>
        <a
          href="/drm-101"
          class="shrink-0 px-6 py-3 bg-coral text-white text-sm font-semibold rounded-lg hover:bg-coral/90 hover:-translate-y-0.5 transition-all duration-300 shadow-lg shadow-coral/20 text-center"
        >
          Or start with DRM 101
        </a>
      </div>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          popularPosts.slice(0, 6).map((post, i) => {
            return (
              <a
                href={`/blog/${post.id}`}
                class="group flex items-start gap-3 p-3 rounded-xl hover:bg-white/[0.04] transition-colors"
              >
                <span class="w-6 h-6 rounded-md bg-coral/10 flex items-center justify-center shrink-0 text-coral font-bold text-xs font-mono mt-0.5">
                  {i + 1}
                </span>
                <span class="text-sm text-gray-300 group-hover:text-white transition-colors leading-snug">
                  {post.data.title}
                </span>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-6 pb-24">
    <!-- Post Grid with Featured -->
    <BlogPostGrid posts={gridPosts} featuredPost={featuredPost} showFeatured={true} />

    <!-- Pagination -->
    <Pagination currentPage={1} totalPages={totalPages} />

    <!-- Newsletter CTA -->
    <div
      class="mt-16 p-8 md:p-10 bg-gradient-to-br from-coral/10 to-deep-blue/30 border border-coral/20 rounded-2xl text-center"
    >
      <p class="text-sm font-mono text-coral uppercase tracking-widest mb-3">
        // never miss a post
      </p>
      <h3 class="text-2xl font-bold text-white mb-3">Get New Articles in Your Inbox</h3>
      <p class="text-gray-400 mb-6 max-w-md mx-auto">
        One email every Tuesday with actionable marketing tactics for developers. Plus the free DRM
        Cheatsheet — every framework and template on one page.
      </p>
      <NewsletterForm size="md" buttonText="Subscribe Free" class="max-w-md mx-auto" />
    </div>
  </div>

  <script>
    document
      .getElementById('blog-search-btn')
      ?.addEventListener('click', () => window.dispatchEvent(new Event('search:open')));
  </script>
</Layout>
