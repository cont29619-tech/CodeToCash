---
import Layout from '../../../layouts/Layout.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';
import BlogPostGrid from '../../../components/BlogPostGrid.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  // Count tag frequencies
  const tagCounts = new Map<string, number>();
  allPosts.forEach((post) => {
    post.data.tags.forEach((tag) => {
      tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
    });
  });

  // Only generate pages for tags with 3+ posts
  const popularTags = [...tagCounts.entries()]
    .filter(([_, count]) => count >= 3)
    .map(([tag]) => tag);

  return popularTags.map((tag) => {
    const tagPosts = allPosts.filter((post) => post.data.tags.includes(tag));
    return {
      params: { tag: tag.toLowerCase().replace(/\s+/g, '-') },
      props: { tag, posts: tagPosts, count: tagPosts.length },
    };
  });
}

const { tag, posts, count } = Astro.props;

const title = `${tag} — Articles | CodeToCash Blog`;
const description = `${count} articles about ${tag} for developers who ship. Actionable tactics, frameworks, and templates.`;

const categories = [
  { id: 'all', label: 'All' },
  { id: 'fundamentals', label: 'Fundamentals' },
  { id: 'copywriting', label: 'Copywriting' },
  { id: 'email', label: 'Email' },
  { id: 'ads', label: 'Ads' },
  { id: 'analytics', label: 'Analytics' },
  { id: 'strategy', label: 'Strategy' },
];
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 md:py-24">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 right-1/4 w-80 h-80 bg-coral/5 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <nav
        aria-label="Breadcrumb"
        class="flex items-center justify-center gap-2 text-sm text-gray-500 mb-6"
      >
        <a href="/" class="hover:text-gray-300 transition-colors">Home</a>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
          ></path></svg
        >
        <a href="/blog" class="hover:text-gray-300 transition-colors">Blog</a>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
          ></path></svg
        >
        <span class="text-gray-400">Tag</span>
      </nav>
      <p class="text-sm font-mono text-coral uppercase tracking-widest mb-4">// tag</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-4">
        {tag}
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        {count} article{count !== 1 ? 's' : ''} about {tag} for developers who ship.
      </p>
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="max-w-5xl mx-auto px-6 mb-12">
    <p class="text-center text-sm font-mono text-coral uppercase tracking-widest mb-4">
      // browse by category
    </p>
    <nav class="flex flex-wrap gap-2 justify-center" aria-label="Blog categories">
      {
        categories.map((cat) => (
          <a
            href={cat.id === 'all' ? '/blog' : `/blog/${cat.id}`}
            class={`px-4 py-2 rounded-xl text-sm font-medium border transition-all ${cat.id === 'all' ? 'bg-coral/10 text-coral border-coral/20' : 'bg-white/5 text-gray-400 border-white/10 hover:text-white hover:border-white/20'}`}
          >
            {cat.label}
          </a>
        ))
      }
    </nav>
  </section>

  <div class="max-w-5xl mx-auto px-6 pb-24">
    <!-- Post Grid -->
    <BlogPostGrid posts={posts} showFeatured={false} />

    <!-- Back to Blog -->
    <div class="mt-12 text-center">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 px-6 py-3 border border-white/20 text-gray-300 text-sm font-medium rounded-lg hover:border-coral/40 hover:text-white transition-all"
      >
        ← Back to all articles
      </a>
    </div>

    <!-- Newsletter CTA -->
    <div
      class="mt-16 p-8 md:p-10 bg-gradient-to-br from-coral/10 to-deep-blue/30 border border-coral/20 rounded-2xl text-center"
    >
      <p class="text-sm font-mono text-coral uppercase tracking-widest mb-3">
        // never miss a post
      </p>
      <h3 class="text-2xl font-bold text-white mb-3">Get New Articles in Your Inbox</h3>
      <p class="text-gray-400 mb-6 max-w-md mx-auto">
        One email every Tuesday with actionable marketing tactics for developers. Plus the free DRM
        Cheatsheet — every framework and template on one page.
      </p>
      <NewsletterForm size="md" buttonText="Subscribe Free" class="max-w-md mx-auto" />
    </div>
  </div>
</Layout>
