---
import Layout from '../../../layouts/Layout.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';
import BlogPostGrid from '../../../components/BlogPostGrid.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { getBlogPagination, getPageStreamSlice } from '../../../utils/blogPagination';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const { stream, totalPages, totalPosts } = getBlogPagination(allPosts);

  const categoryCounts = allPosts.reduce<Record<string, number>>((acc, p) => {
    acc[p.data.category] = (acc[p.data.category] || 0) + 1;
    return acc;
  }, {});

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2;
    return {
      params: { page: String(page) },
      props: {
        posts: getPageStreamSlice(stream, page),
        page,
        totalPages,
        totalPosts,
        categoryCounts,
      },
    };
  });
}

const { posts, page, totalPages, totalPosts, categoryCounts } = Astro.props;

const title = `Blog — Page ${page} | CodeToCash`;
const description = `Page ${page} of ${totalPages}. Actionable marketing articles for developers who ship.`;

const categories = [
  { id: 'all', label: 'All', count: totalPosts },
  { id: 'fundamentals', label: 'Fundamentals', count: categoryCounts.fundamentals || 0 },
  { id: 'copywriting', label: 'Copywriting', count: categoryCounts.copywriting || 0 },
  { id: 'email', label: 'Email', count: categoryCounts.email || 0 },
  { id: 'ads', label: 'Ads', count: categoryCounts.ads || 0 },
  { id: 'analytics', label: 'Analytics', count: categoryCounts.analytics || 0 },
  { id: 'strategy', label: 'Strategy', count: categoryCounts.strategy || 0 },
];
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 md:py-24">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 right-1/4 w-80 h-80 bg-coral/5 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
        Blog — Marketing Tactics for <span class="text-coral">Vibe Coders</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Actionable articles on direct response marketing, copywriting, and growth strategies for
        developers who ship.
      </p>
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="max-w-5xl mx-auto px-6 mb-12">
    <p class="text-center text-sm font-mono text-coral uppercase tracking-widest mb-4">
      // browse by category
    </p>
    <nav class="flex flex-wrap gap-2 justify-center" aria-label="Blog categories">
      {
        categories.map((cat) => (
          <a
            href={cat.id === 'all' ? '/blog' : `/blog/${cat.id}`}
            class={`inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium border transition-all ${cat.id === 'all' ? 'bg-coral/10 text-coral border-coral/20' : 'bg-white/5 text-gray-400 border-white/10 hover:text-white hover:border-white/20'}`}
          >
            {cat.label}
            <span class="text-xs opacity-60">{cat.count}</span>
          </a>
        ))
      }
    </nav>
  </section>

  <div class="max-w-5xl mx-auto px-6 pb-24">
    <p class="text-sm text-gray-500 mb-6 text-center">
      Showing {posts.length} of {totalPosts} articles
    </p>

    <!-- Post Grid -->
    <BlogPostGrid posts={posts} showFeatured={false} />

    <!-- Pagination -->
    <Pagination currentPage={page} totalPages={totalPages} />

    <!-- Newsletter CTA -->
    <div
      class="mt-16 p-8 md:p-10 bg-gradient-to-br from-coral/10 to-deep-blue/30 border border-coral/20 rounded-2xl text-center"
    >
      <p class="text-sm font-mono text-coral uppercase tracking-widest mb-3">
        // never miss a post
      </p>
      <h3 class="text-2xl font-bold text-white mb-3">Get New Articles in Your Inbox</h3>
      <p class="text-gray-400 mb-6 max-w-md mx-auto">
        One email every Tuesday with actionable marketing tactics for developers. Plus the free DRM
        Cheatsheet — every framework and template on one page.
      </p>
      <NewsletterForm size="md" buttonText="Subscribe Free" class="max-w-md mx-auto" />
    </div>
  </div>
</Layout>
